\NeedsTeXFormat{LaTeX2e}[1999/12/01]
\ProvidesPackage{mud-uml}[2016/08/26 UML diagram generation.]

\RequirePackage{pgfkeys}
\RequirePackage{tikz}
\RequirePackage{xstring}
\usetikzlibrary{arrows,arrows.meta,decorations,decorations.markings,fit}
\usetikzlibrary{shapes.multipart,calc}

% ===========================================================================
% Check if TikZ/PGF is of version 3.x
% ===========================================================================
\def\tikzrelease#1.#2\tikzrelease{#1}
\ifnum\expandafter\tikzrelease\pgfversion\tikzrelease=3
\else
  \errmessage{TikZ/PGF (\pgfversion) should be of version 3}\errorstopmode
\fi


% ===========================================================================
% Style: inheritance
% This style is used to draw an inheritance arrow.
% ===========================================================================
\tikzset{inheritance/.style={%
             black,thick,%
             arrows={-Triangle[scale=2,fill=black]}%
        }}%

% ===========================================================================
% Style: realization
% This style is used to draw an inheritance arrow.
% ===========================================================================
\tikzset{realization/.style={%
             dashed,black,thick,%
             arrows={-Triangle[scale=2,fill=white]}%
        }}%

% ===========================================================================
% Style: aggregation
% This style is used to draw an aggregation relationship.
% ===========================================================================
\tikzset{aggregation/.style={%
             black,thick,%
             arrows={-Diamond[scale=2,fill=white]}%
        }}%

% ===========================================================================
% Style: composition
% This style is used to draw a composition relationship.
% ===========================================================================
\tikzset{compostion/.style={%
             black,thick,%
             arrows={-Diamond[scale=2,fill=black]}%
        }}%

% ===========================================================================
% Style: dependency 
% This style is used to draw a dependency relationship.
% ===========================================================================
\tikzset{dependency/.style={%
             dashed,black,thick,%
             arrows={-Straight Barb[scale=2]}%
        }}%

% ===========================================================================A
% Style: lines 
% Line styles for pure horizontal & vertical lines
% ===========================================================================
\tikzset{
  -|-/.style={
    to path={
      (\tikztostart) -| ($(\tikztostart)!#1!(\tikztotarget)$) |- (\tikztotarget)
      \tikztonodes
    }
  },
  -|-/.default=0.5,
  |-|/.style={
    to path={
      (\tikztostart) |- ($(\tikztostart)!#1!(\tikztotarget)$) -| (\tikztotarget)
      \tikztonodes
    }
  },
  |-|/.default=0.5,
}

% ===========================================================================
% Command: \umlclass[options]{class}{attributes}{methods}
%   The attributes and methods are tabular items where the access specifier 
%   and name are the first column and the type is the second column. The
%   columns are separated by the tabular column separator (&) and a new entry
%   is started with the tabular new row command (\\).
% Options are
%    x         The x position coordinate (default: 0)
%    y         The y position coordinate (default: 0)
%    width     The minimum width (default: 20ex)
%    name      The alternative node-name (default: class name without _ or :)
% ===========================================================================
\newcommand{\umlclass}[4][]{%
  \def\classname{#2}%
  \pgfkeys{/uml/class/.cd,%
      x/.initial=0,%
      y/.initial=0,%
      width/.initial=20ex,%
      name/.initial=\classname,%
  }%
  \pgfkeys{/uml/class/.cd,#1}%
  \pgfkeys{/uml/class/.cd,%
      x/.get=\umlclassX,%
      y/.get=\umlclassY,%
      width/.get=\umlclassWidth,%
      name/.get=\umlclassNodeName,%
  }%
  % Ensure that the node-name does not contain any '_' or ':'. These will be
  % deleted from the name.
  \StrSubstitute{\umlclassNodeName}{\_}{}[\umlclassNodeName]%
  \StrSubstitute{\umlclassNodeName}{:}{}[\umlclassNodeName]%
  % Create the class structure using a three-part rectangle. The 
  \path (\umlclassX,\umlclassY) node(\umlclassNodeName) %
                [ anchor=north,% 
                  draw=red!80,thick,%
                  shape=rectangle split,%
                  rectangle split parts=3,%
                  rectangle split part align={center,left,left},%
                  minimum width=\umlclassWidth,%
                  fill=yellow!20 ]%
  { \nodepart{one}{\small\texttt{\bf \classname}}
    \nodepart{two}{\footnotesize\texttt{\frenchspacing%
      \begin{tabular}{@{}l@{: }l}
        #3
      \end{tabular}}}
    \nodepart{three}{\footnotesize\texttt{\frenchspacing%
      \begin{tabular}{@{}l}
        #4
      \end{tabular}}}
  }
}

% ===========================================================================
% Command: \umltenplate[options]{class}{template}{attributes}{methods}
%   The attributes and methods are tabular items where the access specifier 
%   and name are the first column and the type is the second column. The
%   columns are separated by the tabular column separator (&) and a new entry
%   is started with the tabular new row command (\\).
% Options are
%    x         The x position coordinate (default: 0)
%    y         The y position coordinate (default: 0)
%    width     The minimum width (default: 20ex)
%    name      The alternative node-name (default: class name without _ or :)
% ===========================================================================
\newcommand{\umltemplate}[5][]{%
  \umlclass[#1]{#2}{#4}{#5};
  % Draw the template parameter box
  \node [draw,%
         shape=rectangle,%
         dashed,%
         inner sep=5pt,%
         fill=white]%
      at (\umlclassNodeName.north east){\small\texttt{#3}}
}

